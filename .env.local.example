# 이 파일을 .env.local 로 복사한 뒤 각 값을 채우세요.
#   cp .env.local.example .env.local
# 값에 따옴표(")나 등호(=) 주변 공백을 넣지 마세요. (KEY=값  형식 그대로)
# 키를 바꾼 뒤에는: docker compose up -d --force-recreate

# ── 텍스트 생성 (Google Gemini) ──
# 발급: https://aistudio.google.com/apikey  (무료)
GEMINI_API_KEY=AIza_여기에_본인_키

# ── Notion ──
# 토큰 발급: https://www.notion.so/my-integrations → New integration
# 3개 표 모두에 이 인티그레이션을 Connections 로 연결해야 저장됨
NOTION_TOKEN=ntn_여기에_본인_토큰

# 표(데이터베이스) ID = 표 풀페이지 URL의 가운데 32자리
# notion.so/<워크스페이스>/<32자리>?v=...
NOTION_DB_IG=인스타_표_32자리ID
NOTION_DB_BLOG=블로그_표_32자리ID
NOTION_DB_X=X_표_32자리ID
